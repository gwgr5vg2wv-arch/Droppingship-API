generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  admin
  operator
  viewer
}

enum AccountStatus {
  active
  pending
  blocked
  disabled
  deleted
}

enum IntegrationProvider {
  mercadoLivre
  aliexpress
  shopee
  tiktokShop
  amazon
  temu
}

model User {
  id                 String                   @id @default(cuid())
  name               String
  email              String                   @unique
  passwordHash       String
  role               UserRole                 @default(owner)
  status             AccountStatus            @default(pending)
  avatarUrl          String?
  preferences        Json                     @default("{}")
  emailVerifiedAt    DateTime?
  failedLoginCount   Int                      @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  lastLoginAt        DateTime?
  deletedAt          DateTime?
  workspaces         Workspace[]              @relation("WorkspaceOwner")
  memberships        WorkspaceMember[]
  sessions           UserSession[]
  passwordResets     PasswordResetToken[]
  emailVerifications EmailVerificationToken[]
  auditLogs          AuditLog[]

  @@index([status])
}

model Workspace {
  id              String            @id @default(cuid())
  name            String
  ownerId         String
  planId          String?
  status          AccountStatus     @default(active)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  owner           User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members         WorkspaceMember[]
  subscriptions   Subscription[]
  integrations    Integration[]
  research        ProductResearch[]
  savedProducts   SavedProduct[]
  listings        Listing[]
  orders          Order[]
  automationRules AutomationRule[]
  errorEvents     ErrorEvent[]
  auditLogs       AuditLog[]

  @@index([ownerId])
}

model WorkspaceMember {
  id           String        @id @default(cuid())
  workspaceId  String
  userId       String
  role         UserRole      @default(viewer)
  permissions  Json          @default("{}")
  status       AccountStatus @default(active)
  invitedEmail String?
  invitedAt    DateTime?
  joinedAt     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
}

model UserSession {
  id               String    @id @default(cuid())
  userId           String
  workspaceId      String?
  refreshTokenHash String    @unique
  refreshTokenId   String    @unique
  ipAddress        String?
  userAgent        String?
  revokedAt        DateTime?
  revokedReason    String?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastUsedAt       DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
}

model Subscription {
  id                     String    @id @default(cuid())
  workspaceId            String
  provider               String
  externalSubscriptionId String?
  plan                   String
  status                 String
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  workspace              Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Integration {
  id                    String              @id @default(cuid())
  workspaceId           String
  provider              IntegrationProvider
  status                String
  externalAccountId     String?
  accountName           String?
  scopes                Json                @default("[]")
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  expiresAt             DateTime?
  metadata              Json                @default("{}")
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  workspace             Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  listings              Listing[]
  orders                Order[]

  @@unique([workspaceId, provider])
  @@index([provider, status])
}

model ProductSource {
  id                String              @id @default(cuid())
  provider          IntegrationProvider
  externalProductId String
  title             String
  description       String?
  sourceUrl         String?
  sellerId          String?
  sellerName        String?
  currency          String?
  sourcePrice       Decimal?            @db.Decimal(12, 2)
  sourceStock       Int?
  shippingCost      Decimal?            @db.Decimal(12, 2)
  rating            Decimal?            @db.Decimal(4, 2)
  reviewCount       Int?
  orderCount        Int?
  category          String?
  attributes        Json                @default("[]")
  rawData           Json                @default("{}")
  lastSyncedAt      DateTime?
  research          ProductResearch[]
  savedProducts     SavedProduct[]

  @@unique([provider, externalProductId])
  @@index([provider, title])
}

model ProductResearch {
  id                String        @id @default(cuid())
  workspaceId       String
  productSourceId   String
  status            String
  estimatedCost     Decimal?      @db.Decimal(12, 2)
  estimatedFees     Decimal?      @db.Decimal(12, 2)
  estimatedShipping Decimal?      @db.Decimal(12, 2)
  suggestedPrice    Decimal?      @db.Decimal(12, 2)
  estimatedProfit   Decimal?      @db.Decimal(12, 2)
  roi               Decimal?      @db.Decimal(8, 2)
  competitionScore  Int?
  demandScore       Int?
  riskScore         Int?
  aiSummary         Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  workspace         Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  productSource     ProductSource @relation(fields: [productSourceId], references: [id])

  @@index([workspaceId, status])
  @@index([productSourceId])
}

model SavedProduct {
  id              String        @id @default(cuid())
  workspaceId     String
  productSourceId String
  status          String
  notes           String?
  targetPrice     Decimal?      @db.Decimal(12, 2)
  targetMargin    Decimal?      @db.Decimal(8, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  productSource   ProductSource @relation(fields: [productSourceId], references: [id])
  listings        Listing[]

  @@index([workspaceId, status])
}

model Listing {
  id                String              @id @default(cuid())
  workspaceId       String
  integrationId     String
  savedProductId    String
  provider          IntegrationProvider
  externalListingId String?
  title             String
  description       String?
  price             Decimal             @db.Decimal(12, 2)
  currency          String
  stock             Int
  status            String
  permalink         String?
  categoryId        String?
  attributes        Json                @default("[]")
  publishedAt       DateTime?
  lastSyncedAt      DateTime?
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integration       Integration         @relation(fields: [integrationId], references: [id])
  savedProduct      SavedProduct        @relation(fields: [savedProductId], references: [id])
  orderItems        OrderItem[]

  @@index([workspaceId, provider, status])
}

model Order {
  id                 String              @id @default(cuid())
  workspaceId        String
  integrationId      String
  provider           IntegrationProvider
  externalOrderId    String
  status             String
  buyerDataEncrypted String?
  totalAmount        Decimal             @db.Decimal(12, 2)
  marketplaceFees    Decimal?            @db.Decimal(12, 2)
  shippingAmount     Decimal?            @db.Decimal(12, 2)
  estimatedCost      Decimal?            @db.Decimal(12, 2)
  estimatedProfit    Decimal?            @db.Decimal(12, 2)
  currency           String
  orderedAt          DateTime?
  updatedAt          DateTime            @updatedAt
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integration        Integration         @relation(fields: [integrationId], references: [id])
  items              OrderItem[]

  @@unique([provider, externalOrderId])
  @@index([workspaceId, status])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  listingId      String?
  externalItemId String?
  title          String
  quantity       Int
  unitPrice      Decimal  @db.Decimal(12, 2)
  sourceCost     Decimal? @db.Decimal(12, 2)
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listing        Listing? @relation(fields: [listingId], references: [id])

  @@index([orderId])
}

model AutomationRule {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  type        String
  enabled     Boolean   @default(false)
  conditions  Json      @default("{}")
  actions     Json      @default("{}")
  limits      Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, enabled])
}

model ErrorEvent {
  id              String     @id @default(cuid())
  workspaceId     String?
  fingerprint     String
  source          String
  severity        String
  message         String
  stackTrace      String?
  context         Json       @default("{}")
  occurrenceCount Int        @default(1)
  firstSeenAt     DateTime   @default(now())
  lastSeenAt      DateTime   @default(now())
  status          String
  workspace       Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  patches         AIPatch[]

  @@index([workspaceId, status])
  @@index([fingerprint])
}

model AIPatch {
  id               String     @id @default(cuid())
  errorEventId     String
  status           String
  diagnosis        String?
  patch            String?
  filesChanged     Json       @default("[]")
  testsExecuted    Json       @default("[]")
  testResults      Json       @default("{}")
  riskLevel        String
  requiresApproval Boolean    @default(true)
  approvedBy       String?
  appliedAt        DateTime?
  rolledBackAt     DateTime?
  errorEvent       ErrorEvent @relation(fields: [errorEventId], references: [id], onDelete: Cascade)

  @@index([errorEventId, status])
}

model AuditLog {
  id          String     @id @default(cuid())
  workspaceId String?
  userId      String?
  action      String
  entity      String
  entityId    String?
  before      Json?
  after       Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime   @default(now())
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
}
