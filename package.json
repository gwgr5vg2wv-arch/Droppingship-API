{
  "name": "droppingship-saas-erp",
  "version": "1.0.0",
  "description": "Base SaaS/ERP de dropshipping com integracoes reais.",
  "type": "module",
  "scripts": {
    "dev": "node --watch server/index.js",
    "start": "node server/index.js",
