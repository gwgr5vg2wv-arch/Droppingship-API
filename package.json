    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "openai": "^4.77.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
